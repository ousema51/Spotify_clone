MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-key-change-this

# yt-dlp auth/session options (set at least one when YouTube bot challenge occurs)
# YTDLP_COOKIEFILE=/absolute/path/to/youtube-cookies.txt
# YTDLP_COOKIES_B64=<base64-encoded Netscape cookie file>
# YTDLP_COOKIES_FROM_BROWSER=chrome:Default
# YTDLP_PO_TOKEN=<optional yt-dlp po token>
# YTDLP_VISITOR_DATA=<optional visitor data>
# PIPED_INSTANCES=https://pipedapi.adminforge.de,https://pipedapi.kavin.rocks

# External yt-dlp API mode (RapidAPI)
# YTDLP_PROVIDER=rapidapi
# YTDLP_RAPIDAPI_KEY=<your rapidapi key>
# YTDLP_RAPIDAPI_HOST=yt-dlp-api.p.rapidapi.com
# YTDLP_RAPIDAPI_URL=https://yt-dlp-api.p.rapidapi.com/
# YTDLP_ALLOW_LOCAL_FALLBACK=0

# Optional local fallback without env vars:
# Place cookies in backend/cookies/cookie.b64 or backend/cookies/cookie.txt
